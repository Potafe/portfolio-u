# ─── Remote résumé source ────────────────────────────────────────────────────
# When set, the /api/resume endpoint fetches the .sty LaTeX source from this
# URL instead of reading src/data/resume.sty from disk.
# Examples:
#   RESUME_URL=https://gist.githubusercontent.com/user/HASH/raw/resume.sty
#   RESUME_URL=https://s3.amazonaws.com/my-bucket/resume.sty
#   RESUME_URL=https://www.dropbox.com/s/HASH/resume.sty?dl=1
# RESUME_URL=

# ─── Contact form ─────────────────────────────────────────────────────────────
# Recipient address for contact form submissions.
# If unset, /api/contact falls back to NEXT_PUBLIC_CONTACT_EMAIL; if neither is
# set, contact form submissions will not be delivered.
# CONTACT_TO_EMAIL=you@example.com

# ─── Resend API (contact form e-mail delivery) ───────────────────────────────
# Sign up at https://resend.com — free tier covers 3 000 emails/month.
# RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx
#
# Sender address and display name.
# Use a verified domain in Resend for best deliverability.
# Falls back to onboarding@resend.dev (Resend sandbox) if not set.
# CONTACT_FROM_EMAIL=noreply@yourdomain.com
# CONTACT_FROM_LABEL=Portfolio Contact
