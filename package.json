    "globals": "^17.5.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.2",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.58.1"
  },
  "dependencies": {
    "@expo-google-fonts/tinos": "^0.4.1",
    "@fontsource/tinos": "^5.2.7",
